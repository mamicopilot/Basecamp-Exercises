{
  "tools": [
    {
      "name": "get_ticket",
      "description": "チケットを取得する",
      "input_schema": {
        "type": "object",
        "properties": {
          "ticket_id": {
            "type": "string"
          }
        },
        "required": [
          "ticket_id"
        ]
      }
    },
    {
      "name": "lookup_customer_by_email",
      "description": "顧客を検索する",
      "input_schema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ]
      }
    },
    {
      "name": "check_sso_config",
      "description": "SSO の設定",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "check_audit_log",
      "description": "監査ログのクエリ",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "after": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "get_workspace_account_summary",
      "description": "ワークスペースのサマリー。TODO: get_customer_details とマージ？",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "list_workspace_users",
      "description": "ユーザー一覧を表示する",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member",
              "viewer"
            ]
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "modify_permissions",
      "description": "ユーザーのロールを変更する。",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "user_email": {
            "type": "string"
          },
          "new_role": {
            "type": "string",
            "enum": [
              "admin",
              "member",
              "viewer"
            ]
          }
        },
        "required": [
          "customer_id",
          "user_email",
          "new_role"
        ]
      }
    },
    {
      "name": "reset_2fa",
      "description": "2FA リセット",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "user_email": {
            "type": "string"
          }
        },
        "required": [
          "customer_id",
          "user_email"
        ]
      }
    }
  ]
}