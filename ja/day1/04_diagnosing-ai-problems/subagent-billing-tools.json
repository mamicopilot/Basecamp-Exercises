{
  "tools": [
    {
      "name": "get_ticket",
      "description": "チケットを取得する",
      "input_schema": {
        "type": "object",
        "properties": {
          "ticket_id": {
            "type": "string"
          }
        },
        "required": [
          "ticket_id"
        ]
      }
    },
    {
      "name": "lookup_customer_by_email",
      "description": "顧客を検索する",
      "input_schema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ]
      }
    },
    {
      "name": "get_billing_history",
      "description": "顧客の請求履歴",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "check_plan_entitlements",
      "description": "プランのエンタイトルメントを返す。",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "issue_refund",
      "description": "返金を実行する。内部で Stripe を呼び出す。",
      "input_schema": {
        "type": "object",
        "properties": {
          "transaction_id": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "reason": {
            "type": "string",
            "enum": [
              "duplicate_charge",
              "billing_error",
              "service_credit",
              "goodwill"
            ]
          }
        },
        "required": [
          "transaction_id",
          "amount",
          "reason"
        ]
      }
    },
    {
      "name": "adjust_invoice",
      "description": "請求書の調整",
      "input_schema": {
        "type": "object",
        "properties": {
          "invoice_id": {
            "type": "string"
          },
          "credit_amount": {
            "type": "number"
          },
          "credit_description": {
            "type": "string"
          }
        },
        "required": [
          "invoice_id",
          "credit_amount",
          "credit_description"
        ]
      }
    },
    {
      "name": "check_payment_method",
      "description": "支払い方法の情報",
      "input_schema": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    }
  ]
}